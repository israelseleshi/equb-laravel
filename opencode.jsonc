{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "directories": [
      ".opencode/skills",
      "../ECC/skills"
    ],
    "autoLoad": [
      "expo-react-native-typescript",
      "react-native",
      "tdd-workflow",
      "coding-standards",
      "frontend-patterns",
      "security-review",
      "verification-loop",
      "laravel-patterns",
      "laravel-tdd",
      "laravel-security",
      "laravel-verification",
      "backend-patterns",
      "database-migrations",
      "expo",
      "react-patterns",
      "react-testing",
      "react-performance",
      "typescript-patterns",
      "laravel-patterns",
      "php-patterns",
      "database-migrations",
      "security-review",
      "e2e-testing"
    ]
  },
  "commands": {
    "directories": [
      "../ECC/commands"
    ]
  },
  "agents": {
    "directories": [
      "../ECC/agents"
    ]
  },
  "rules": {
    "directories": [
      "../ECC/rules"
    ]
  }
}
